{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "verilog",
      "camelcase": "Verilog",
      "title": "Verilog",
      "scope": "source.verilog",
      "file-types": [
        "verilog"
      ],
      "injection-regex": "^verilog$",
      "class-name": "TreeSitterVerilog"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Verilog grammar for tree-sitter",
    "authors": [
      {
        "name": "zhangwwpeng",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-verilog",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "java": false,
    "node": false,
    "python": true,
    "rust": true,
    "swift": false,
    "zig": false
  }
}